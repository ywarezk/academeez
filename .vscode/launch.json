{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
      "args": [
        "-u",
        "bdd",
        "--timeout",
        "999999",
        "-r",
        "../../node_modules/ts-node/register",
        "-r",
        "../../node_modules/tsconfig-paths/register",
        "--colors",
        "**/*.spec.ts"
      ],
      "internalConsoleOptions": "openOnSessionStart",
      "name": "test github-api",
      "program": "${workspaceFolder}/node_modules/mocha/bin/_mocha",
      "request": "launch",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node",
      "runtimeVersion": "14.15.0",

      // public env vars here
      "env": {
        "TS_NODE_PROJECT": "./tsconfig.spec.json",
        "port": "3333"
      },

      // private env vars here
      "envFile": "${workspaceFolder}/apps/github-api/.env",
      "cwd": "${workspaceFolder}/apps/github-api"
    }
	]
}
