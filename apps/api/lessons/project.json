{
  "root": "apps/api/lessons",
  "sourceRoot": "apps/api/lessons/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nrwl/node:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/api/lessons",
        "main": "apps/api/lessons/src/main.ts",
        "tsConfig": "apps/api/lessons/tsconfig.app.json",
        "assets": ["apps/api/lessons/src/assets"]
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false,
          "fileReplacements": [
            {
              "replace": "apps/api/lessons/src/environments/environment.ts",
              "with": "apps/api/lessons/src/environments/environment.prod.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "builder": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          "exit 0;"
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/api/lessons/**/*.ts"]
      }
    }
  },
  "tags": []
}
