{
  "root": "apps/api/lessons",
  "sourceRoot": "apps/api/lessons/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nrwl/node:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/api/lessons",
        "main": "apps/api/lessons/index.ts",
        "generatePackageJson": true,
        "outputFileName": "index.js",
        "tsConfig": "apps/api/lessons/tsconfig.app.json"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        }
      }
    },
    "serve": {
      "builder": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          "exit 0;"
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/api/lessons/**/*.ts"]
      }
    },
    "test": {
      "builder": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          "npm run test:server -- api/lessons"
        ]
      }
    }
  },
  "tags": []
}
