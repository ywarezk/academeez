{
  "root": "apps/api/lessons",
  "sourceRoot": "apps/api/lessons/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nrwl/node:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/api/lessons",
        "main": "apps/api/lessons/index.ts",
        "generatePackageJson": true,
        "outputFileName": "index.js",
        "tsConfig": "apps/api/lessons/tsconfig.app.json"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        }
      }
    },
    "serve": {
      "builder": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          "exit 0;"
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/api/lessons/**/*.ts"]
      }
    },
    "test": {
      "builder": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          "npm run test:server -- apps/api/lessons"
        ]
      }
    },
    "deploy": {
      "builder": "@nrwl/workspace:run-commands",
      "configurations": {
        "development": {
          "commands": [
            "gcloud functions deploy api --runtime nodejs16 --trigger-http --project prj-academeez-dev-bdd2 --entry-point app --source dist/apps/api/lessons --service-account=sa-api-lessons@prj-academeez-dev-bdd2.iam.gserviceaccount.com"
          ]
        }
      }

    }
  },
  "tags": []
}
