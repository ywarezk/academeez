{
  "root": "apps/api",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nrwl/node:webpack",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/api",
        "main": "apps/api/src/app.ts",
        "tsConfig": "apps/api/tsconfig.app.json",
        "generatePackageJson": true,
        "optimization": true,
        "extractLicenses": true,
        "inspect": false,
        "sourceMap": false
      }
    },
    "buildServe": {
      "executor": "@nrwl/node:webpack",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/api",
        "main": "apps/api/src/main.ts",
        "tsConfig": "apps/api/tsconfig.app.json"
      }
    },
    "serve": {
      "executor": "@nrwl/node:node",
      "options": {
        "buildTarget": "api:buildServe",
        "inspect": true,
        "port": 7777
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/api/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": ["npx nz test:mocha apps/api"]
      }
    },
    "deploy": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          "npx nx run api:build",
          "gcloud beta functions deploy api --set-secrets 'GITHUB_TOKEN=projects/858548677058/secrets/github-token:latest' --runtime nodejs16 --trigger-http --project prj-academeez --entry-point app --source dist/apps/api --service-account=sa-api-lessons@prj-academeez.iam.gserviceaccount.com"
        ],
        "parallel": false
      }
    },
    "e2e": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          "exit 0;"
        ]
      }
    }
  },
  "tags": []
}
