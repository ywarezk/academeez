{
  "root": "apps/api",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nrwl/node:webpack",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/api",
        "main": "apps/api/src/index.ts",
        "tsConfig": "apps/api/tsconfig.app.json"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        }
      }
    },
    "serve": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": ["exit 0;"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/api/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": ["npx nz test:mocha apps/api"]
      }
    },
    "deploy": {
      "executor": "@nrwl/workspace:run-commands",
      "configurations": {
        "development": {
          "commands": [
            "gcloud beta functions deploy api --set-secrets 'GITHUB_TOKEN=projects/288211122591/secrets/github-token:latest' --runtime nodejs16 --trigger-http --project prj-academeez-dev-bdd2 --entry-point app --source dist/apps/api --service-account=sa-api-lessons@prj-academeez-dev-bdd2.iam.gserviceaccount.com"
          ]
        }
      }
    }
  },
  "tags": []
}
