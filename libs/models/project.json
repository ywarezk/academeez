{
  "root": "libs/models",
  "sourceRoot": "libs/models/src",
  "projectType": "library",
  "targets": {
    "build": {
      "builder": "@nrwl/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/models",
        "tsConfig": "libs/models/tsconfig.lib.json",
        "packageJson": "libs/models/package.json",
        "main": "libs/models/src/index.ts",
        "assets": [
          "libs/models/*.md"
        ]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "libs/models/**/*.ts"
        ]
      }
    },
    "test": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          "npx nz test:mocha libs/models --prod"
        ]
      }
    }
  },
  "tags": []
}
