    "@astrojs/starlight": "^0.39.2",
    "@astrojs/starlight-tailwind": "^3.0.1",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "10.0.6",
    "@codesandbox/sandpack-react": "^2.18.2",
    "@fontsource/inter": "^5.0.18",
    "@fortawesome/fontawesome-free": "^6.6.0",
    "@iconify-json/logos": "^1.2.3",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "astro": "^6.3.1",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.1.8",
    "lucide-react": "^0.427.0",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.54.2",
    "@semantic-release/git": "^10.0.1",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.3.0",
    "@typescript-eslint/parser": "^8.40.0",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "lint-staged": "^15.4.3",
    "nyc": "^17.1.0",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "semantic-release": "^24.2.7",
    "typescript-eslint": "^8.21.0",
    "unist-util-visit": "^5.0.0",
    "vite-plugin-istanbul": "^7.2.1"
  },
  "packageManager": "pnpm@10.23.0",
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/github",
      "@semantic-release/git"
    ]
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "@astrojs/vercel>esbuild": "0.25.0",
      "mdast-util-to-hast": "13.2.1",
      "@mapbox/node-pre-gyp>tar": "7.5.11",
      "@iconify/tools>tar": "7.5.11",
      "@iconify/tools>axios": "1.16.0",
      "astro>svgo": "4.0.1",
      "@iconify/tools>svgo": "3.3.3",
      "undici": "6.24.0",
      "vite>rollup": "4.59.0",
      "eslint>minimatch": "3.1.4",
      "@typescript-eslint/typescript-estree>minimatch": "9.0.7",
      "glob>minimatch": "3.1.4",
      "test-exclude>minimatch": "9.0.7",
      "flatted": "3.4.2",
      "yaml-language-server>ajv": "8.18.0",
      "conventional-changelog-writer>handlebars": "4.7.9",
      "minimatch@3.1.4>brace-expansion": "1.1.13",
      "picomatch@^2.3.1": "2.3.2",
      "picomatch@^4.0.0": "4.0.4",
      "mermaid>dompurify": "3.4.0",
      "mermaid>uuid": "11.1.1",
      "defu": "6.1.7",
      "fast-uri": "3.1.2",
      "yaml": "2.8.3"
    }
  },
  "nyc": {
    "temp-dir": ".nyc_output",
    "report-dir": "coverage",
    "reporter": [
      "lcov"
    ],
    "extension": [
      ".ts",
      ".tsx",
      ".js",
      ".jsx"
    ],
    "exclude": [
      "**/*.spec.*",
      "**/*.test.*",
      "playwright.config.*",
      "tests/**"
    ],
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "src/**/*.js",
      "src/**/*.jsx"
    ],
    "all": true
  }
}
