---
import { CourseCarousel } from './CourseCarousel';
import { getCollection } from 'astro:content';

interface Props {
	title: string;
	courseLink: string;
}

let locale = Astro.currentLocale;
if (locale === 'en' || !locale) {
	locale = '';
} else {
	locale = `/${locale}`;
}

const courseLink = Astro.props.courseLink || Astro.props.title.toLowerCase();

const collections = await getCollection('docs', (content) => {
	let prefix = '';
	if (locale) {
		prefix = `${locale.substring(1)}/courses/${courseLink}`;
	} else {
		prefix = `courses/${courseLink}`;
	}

	// Match either the exact course root (`courses/git`) or its direct descendants
	// (`courses/git/...`), but avoid prefix collisions like `courses/github`.
	const isInCourse = content.id === prefix || content.id.startsWith(`${prefix}/`);

	return content.data.template === 'doc' && isInCourse && content.data.preview;
}).then((allCollections) => {
	return allCollections.sort(
		(a: (typeof allCollections)[number], b: (typeof allCollections)[number]) => {
			return (a.data.sidebar.order || 0) - (b.data.sidebar.order || 0);
		}
	);
});
---

<CourseCarousel client:load {...Astro.props} locale={locale} articles={collections} />
