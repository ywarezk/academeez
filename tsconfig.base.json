{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@az/academeez/app": ["apps/academeez/app/index.ts"],
      "@az/blog": ["libs/blog/src/index.ts"],
      "@az/courses": ["libs/courses/src/index.ts"],
      "@az/designs": ["libs/designs/src/index.ts"],
      "@az/prd": ["libs/prd/src/index.ts"],
      "@az/mui": ["libs/mui/src/index.ts"],
      "@az/styles": ["libs/styles/src/index.ts"]
    },
    "types": ["node", "express", "mocha"]
  },
  "exclude": ["node_modules", "tmp"]
}
