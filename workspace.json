{
  "version": 2,
  "projects": {
    "academeez": {
      "root": "apps/academeez",
      "sourceRoot": "apps/academeez",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "root": "apps/academeez",
            "outputPath": "dist/apps/academeez"
          },
          "configurations": {
            "production": {}
          }
        },
        "serve-standalone": {
          "executor": "@nrwl/next:server",
          "options": {
            "buildTarget": "academeez:build",
            "dev": true,
            "proxyConfig": "apps/academeez/proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "academeez:build:production",
              "dev": false
            }
          }
        },
        "serve": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": ["npx nx run academeez:serve-standalone"]
          }
        },
        "export": {
          "executor": "@nrwl/next:export",
          "options": {
            "buildTarget": "academeez:build:production"
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/academeez/**/*.{ts,tsx,js,jsx}"]
          },
          "outputs": ["{options.outputFile}"]
        }
      },
      "tags": []
    },
    "academeez-e2e": {
      "root": "apps/academeez-e2e",
      "sourceRoot": "apps/academeez-e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "apps/academeez-e2e/cypress.json",
            "tsConfig": "apps/academeez-e2e/tsconfig.e2e.json",
            "devServerTarget": "academeez:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "academeez:serve:production"
            }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/academeez-e2e/**/*.{js,ts}"]
          },
          "outputs": ["{options.outputFile}"]
        }
      },
      "tags": [],
      "implicitDependencies": ["academeez"]
    },
    "blog": {
      "root": "libs/blog",
      "sourceRoot": "libs/blog/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/blog/**/*.ts"]
          },
          "outputs": ["{options.outputFile}"]
        },
        "build": {
          "executor": "@nrwl/node:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/blog",
            "tsConfig": "libs/blog/tsconfig.lib.json",
            "packageJson": "libs/blog/package.json",
            "main": "libs/blog/src/index.ts",
            "assets": ["libs/blog/*.md"]
          }
        }
      },
      "tags": []
    },
    "courses": {
      "root": "libs/courses",
      "sourceRoot": "libs/courses/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/courses/**/*.ts"]
          },
          "outputs": ["{options.outputFile}"]
        },
        "build": {
          "executor": "@nrwl/node:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/courses",
            "tsConfig": "libs/courses/tsconfig.lib.json",
            "packageJson": "libs/courses/package.json",
            "main": "libs/courses/src/index.ts",
            "assets": ["libs/courses/*.md"]
          }
        }
      },
      "tags": []
    },
    "designs": {
      "root": "libs/designs",
      "sourceRoot": "libs/designs/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/designs/**/*.ts"]
          },
          "outputs": ["{options.outputFile}"]
        },
        "build": {
          "executor": "@nrwl/node:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/designs",
            "tsConfig": "libs/designs/tsconfig.lib.json",
            "packageJson": "libs/designs/package.json",
            "main": "libs/designs/src/index.ts",
            "assets": ["libs/designs/*.md"]
          }
        }
      },
      "tags": []
    },
    "mui": {
      "root": "libs/mui",
      "sourceRoot": "libs/mui/src",
      "projectType": "library",
      "tags": [],
      "targets": {
        "build": {
          "executor": "@nrwl/web:rollup",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/mui",
            "tsConfig": "libs/mui/tsconfig.lib.json",
            "project": "libs/mui/package.json",
            "entryFile": "libs/mui/src/index.ts",
            "external": ["react/jsx-runtime"],
            "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
            "compiler": "babel",
            "assets": [
              {
                "glob": "libs/mui/README.md",
                "input": ".",
                "output": "."
              }
            ]
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["libs/mui/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": [
              {
                "command": "npm run test:package -- libs/mui {args.dev}"
              }
            ]
          }
        }
      }
    },
    "prd": {
      "root": "libs/prd",
      "sourceRoot": "libs/prd/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/prd/**/*.ts"]
          },
          "outputs": ["{options.outputFile}"]
        },
        "build": {
          "executor": "@nrwl/node:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/prd",
            "tsConfig": "libs/prd/tsconfig.lib.json",
            "packageJson": "libs/prd/package.json",
            "main": "libs/prd/src/index.ts",
            "assets": ["libs/prd/*.md"]
          }
        }
      },
      "tags": []
    },
    "styles": {
      "root": "libs/styles",
      "sourceRoot": "libs/styles/src",
      "projectType": "library",
      "tags": [],
      "targets": {
        "build": {
          "executor": "@nrwl/web:rollup",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/styles",
            "tsConfig": "libs/styles/tsconfig.lib.json",
            "project": "libs/styles/package.json",
            "entryFile": "libs/styles/src/index.ts",
            "external": ["react/jsx-runtime"],
            "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
            "compiler": "babel",
            "assets": [
              {
                "glob": "libs/styles/README.md",
                "input": ".",
                "output": "."
              }
            ]
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["libs/styles/**/*.{ts,tsx,js,jsx}"]
          }
        }
      }
    }
  }
}
