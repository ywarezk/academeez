{
  "version": 2,
  "cli": { "defaultCollection": "@nrwl/express" },
  "defaultProject": "courses-api",
  "generators": {
    "@nrwl/react": { "application": { "babel": true } },
    "@nrwl/next": {
      "application": { "style": "styled-components", "linter": "eslint" }
    }
  },
  "projects": {
    "courses-api": {
      "root": "apps/courses-api",
      "sourceRoot": "apps/courses-api/src",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/node:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/apps/courses-api",
            "main": "apps/courses-api/src/main.ts",
            "tsConfig": "apps/courses-api/tsconfig.app.json",
            "assets": ["apps/courses-api/src/assets"]
          },
          "configurations": {
            "production": {
              "optimization": true,
              "extractLicenses": true,
              "inspect": false,
              "fileReplacements": [
                {
                  "replace": "apps/courses-api/src/environments/environment.ts",
                  "with": "apps/courses-api/src/environments/environment.prod.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "executor": "@nrwl/node:execute",
          "options": { "buildTarget": "courses-api:build" }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": { "lintFilePatterns": ["apps/courses-api/**/*.ts"] }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/courses-api"],
          "options": {
            "jestConfig": "apps/courses-api/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "lessons": {
      "root": "libs/lessons",
      "sourceRoot": "libs/lessons/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": { "lintFilePatterns": ["libs/lessons/**/*.ts"] }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/lessons"],
          "options": {
            "jestConfig": "libs/lessons/jest.config.js",
            "passWithNoTests": true
          }
        },
        "build": {
          "executor": "@nrwl/node:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/lessons",
            "tsConfig": "libs/lessons/tsconfig.lib.json",
            "packageJson": "libs/lessons/package.json",
            "main": "libs/lessons/src/index.ts",
            "assets": ["libs/lessons/*.md"]
          }
        }
      }
    },
    "academeez": {
      "root": "apps/academeez",
      "sourceRoot": "apps/academeez",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "root": "apps/academeez",
            "outputPath": "dist/apps/academeez"
          },
          "configurations": { "production": {} }
        },
        "serve": {
          "executor": "@nrwl/next:server",
          "options": { "buildTarget": "academeez:build", "dev": true },
          "configurations": {
            "production": {
              "buildTarget": "academeez:build:production",
              "dev": false
            }
          }
        },
        "export": {
          "executor": "@nrwl/next:export",
          "options": { "buildTarget": "academeez:build:production" }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/academeez"],
          "options": {
            "jestConfig": "apps/academeez/jest.config.js",
            "passWithNoTests": true
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/academeez/**/*.{ts,tsx,js,jsx}"]
          }
        }
      }
    },
    "academeez-e2e": {
      "root": "apps/academeez-e2e",
      "sourceRoot": "apps/academeez-e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "apps/academeez-e2e/cypress.json",
            "tsConfig": "apps/academeez-e2e/tsconfig.e2e.json",
            "devServerTarget": "academeez:serve"
          },
          "configurations": {
            "production": { "devServerTarget": "academeez:serve:production" }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": { "lintFilePatterns": ["apps/academeez-e2e/**/*.{js,ts}"] }
        }
      }
    },
    "designs": {
      "root": "libs/designs",
      "sourceRoot": "libs/designs/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": { "lintFilePatterns": ["libs/designs/**/*.ts"] }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/designs"],
          "options": {
            "jestConfig": "libs/designs/jest.config.js",
            "passWithNoTests": true
          }
        },
        "build": {
          "executor": "@nrwl/node:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/designs",
            "tsConfig": "libs/designs/tsconfig.lib.json",
            "packageJson": "libs/designs/package.json",
            "main": "libs/designs/src/index.ts",
            "assets": ["libs/designs/*.md"]
          }
        }
      }
    }
  }
}
